# alertmanager Secret 템플릿
# 사용법:
#   1. 이 파일을 복사: cp alertmanager-secret.yaml.example alertmanager-secret.yaml
#   2. slack_api_url 과 channel 을 실제 값으로 수정
#   3. kubectl apply -f base/alertmanager-secret.yaml
#
# alertmanager-secret.yaml 은 .gitignore 에 등록되어 커밋되지 않습니다.

apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-config
  namespace: shopping-mall
type: Opaque
stringData:
  alertmanager.yml: |
    global:
      resolve_timeout: 5m
      slack_api_url: 'https://hooks.slack.com/services/YOUR/WEBHOOK/URL'

    route:
      group_by: ['alertname', 'job']
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 1h
      receiver: 'slack-notifications'

    receivers:
      - name: 'slack-notifications'
        slack_configs:
          - channel: '#alerts'
            send_resolved: true
            title: '[{{ .Status | toUpper }}] {{ .CommonAnnotations.summary }}'
            text: |
              <@YOUR_BOT_MEMBER_ID> 알람이 발생했습니다.
              {{ range .Alerts }}
              *Alert:* {{ .Annotations.summary }}
              *Severity:* {{ .Labels.severity }}
              *Service:* {{ .Labels.job }}
              *Description:* {{ .Annotations.description }}
              {{ end }}
            color: '{{ if eq .Status "firing" }}danger{{ else }}good{{ end }}'
